# 🔒 環境設定テンプレート
# このファイルを .env にコピーして、各自の環境に合わせて編集してください
# ⚠️ .env ファイルは機密情報を含むため、GitHub にアップロードしないこと！

# Google Drive 監視フォルダのパス
# 例: ~/Library/CloudStorage/GoogleDrive-your-email@gmail.com/マイドライブ/My_Context_Bank_2026/XX_Gemini_Context
CLEAN_GEMINI_TARGET_DIR="~/Library/CloudStorage/GoogleDrive-your-email@gmail.com/マイドライブ/Your_Folder_Name/XX_Gemini_Context"

# ダウンロード先フォルダ（通常は変更不要）
# CLEAN_GEMINI_DEST_DIR="~/Downloads"
